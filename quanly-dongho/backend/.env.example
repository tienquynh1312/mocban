# ============================================================
# CẤU HÌNH MÔI TRƯỜNG BACKEND — Quản lý Dòng họ
# Sao chép file này thành .env và điền thông tin thực tế
# ============================================================

# Server
PORT=3001
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=nava_dongho_db

# JWT Secret — đổi thành chuỗi ngẫu nhiên dài ≥32 ký tự
JWT_SECRET=your_super_secret_key_change_this_in_production_2026
JWT_EXPIRES_IN=7d

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:5173

# Mã mời hợp lệ (phân cách bằng dấu phẩy)
VALID_INVITE_CODES=SYSTEM_ROOT,NGUYEN_BA_TRA_CUU,NGUYEN_BA_TRUONG,QUY_DONG_HO_2026,CONCHAU_BUI_GIA,NGUYENBAPHA2026,ABC123XYZ
